# dist/ is intentionally tracked so the Pages workflow can deploy without
# running a fresh build in CI (the pnpm + Vite chain kept failing silently).
# Rebuild locally with `pnpm run build:css && pnpm exec vite build --base=./`
# and commit the refreshed dist/ when source changes.

