+  --bn-text-stat: 26px;
+  --bn-text-hero: 38px;
+
+  --bn-gap-1: 4px;
+  --bn-gap-2: 8px;
+  --bn-gap-3: 12px;
+  --bn-gap-4: 16px;
+  --bn-gap-5: 24px;
