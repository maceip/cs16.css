+  copy: (
+    <path d="M3 1 h8 v2 h-6 v8 h-2 z M5 3 h8 v10 h-8 z" fill="currentColor" />
+  ),
+  check: <path d="M2 7 l3 3 l7 -7 l-1 -1 l-6 6 l-2 -2 z" fill="currentColor" />,
+  x: <path d="M3 3 l8 8 M11 3 l-8 8" stroke="currentColor" strokeWidth="1.5" />,
+  search: (
