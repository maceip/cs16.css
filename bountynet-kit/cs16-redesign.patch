+
+  --bn-accent: hsl(193 58% 70%);
+  --bn-accent-dim: hsl(193 35% 42%);
+  --bn-accent-ink: hsl(213 30% 8%);
+
+  --bn-green: hsl(92 32% 65%);
+  --bn-yellow: hsl(40 71% 70%);
+  --bn-orange: hsl(14 55% 62%);
+  --bn-red: hsl(355 55% 66%);
+  --bn-purple: hsl(311 28% 66%);
+
+  --bn-border: hsl(217 17% 28%);
+  --bn-border-light: hsl(217 14% 38%);
+  --bn-border-dark: hsl(215 22% 6%);
+  --bn-border-focus: hsl(193 58% 70%);
