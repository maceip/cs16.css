+};
+
+const CommandList = ({ title, items, onSelect, highlighted = 0, empty }) => (
+  <div style={{ display: 'grid', gap: 4 }}>
+    <span className="bn-eyebrow">{title}</span>
+    {items.length === 0 ? (
