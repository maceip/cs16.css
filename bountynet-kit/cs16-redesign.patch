+
+/* -------------------------------------------------------------------------
+ * Icons (wrapper)
+ * ---------------------------------------------------------------------- */
+
+.bn-icon {
+  display: inline-flex;
+  flex: 0 0 auto;
+  width: 14px;
+  height: 14px;
