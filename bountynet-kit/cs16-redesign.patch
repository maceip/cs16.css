+}
+
+/* -------------------------------------------------------------------------
+ * Toolbar / row helpers
+ * ---------------------------------------------------------------------- */
+
+.bn-row {
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  gap: var(--bn-gap-2);
+}
+
+.bn-stack {
