+    (command) => {
+      if (!command) return;
+      const next = [command.path, ...recents.filter((p) => p !== command.path)];
+      setRecents(next);
+      writeRecents(next);
+      setOpen(false);
+      navigate(command.path);
+    },
+    [navigate, recents],
+  );
+
