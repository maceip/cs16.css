+}
+
+.bn-link:hover {
+  border-bottom-color: var(--bn-accent);
+}
+
+/* -------------------------------------------------------------------------
+ * Separator
+ * ---------------------------------------------------------------------- */
+
+.bn-separator {
+  height: 0;
+  border: 0;
+  border-top: 1px solid var(--bn-border-dark);
+  box-shadow: 0 1px 0 var(--bn-border-light);
